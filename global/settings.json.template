{
  "env": {
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5-20251001",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-6",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "*",
      "mcp__pencil"
    ],
    "deny": [],
    "defaultMode": "acceptEdits"
  },
  "model": "opus[1m]",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/validation-not-compilation.js\""
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/completion-claim-validator.js\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/dev-server-restart-reminder.js\""
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/skill-invocation-tracker.js\""
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/post-edit-simplify-reminder.cjs\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/descriptive-name.cjs\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/block-test-files.js\""
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/plan-before-execute.js\""
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/read-before-edit.js\""
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/subagent-context-enforcer.js\""
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/sdk-auth-subagent-enforcer.js\""
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/evidence-gate-reminder.js\""
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/privacy-block.cjs\""
          }
        ]
      },
      {
        "matcher": "Read|Bash|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/scout-block.cjs\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/session-init.cjs\""
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/session-sdk-context.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ \"$PROJEKT_TERMINAL\" = \"1\" ] && afplay /System/Library/Sounds/Submarine.aiff || true"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/subagent-init.cjs\""
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/team-context-inject.cjs\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "Plan",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/cook-after-plan-reminder.cjs\""
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/task-completed-handler.cjs\""
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/teammate-idle-handler.cjs\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/dev-rules-reminder.cjs\""
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/skill-activation-forced-eval.js\""
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/documentation-context-check.js\""
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/usage-context-awareness.cjs\"",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "autoAllowedTools": [],
  "statusLine": {
    "type": "command",
    "command": "node __HOME__/.claude/hud/omc-hud.mjs"
  },
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-mem@thedotmack": true,
    "claude-skills-troubleshooting@daymade-skills": true,
    "code-review@claude-plugins-official": true,
    "everything-claude-code@everything-claude-code": true,
    "kaizen@context-engineering-kit": true,
    "oh-my-claudecode@omc": true,
    "planning-with-files@planning-with-files": true,
    "plugin-dev@claude-plugins-official": true,
    "reflexion@context-engineering-kit": true,
    "sadd@context-engineering-kit": true,
    "skill-creator@claude-plugins-official": true,
    "skill-judge@agent-toolkit": true,
    "skills-search@daymade-skills": true,
    "start@the-startup": true,
    "taches-cc-resources@taches-cc-resources": true
  },
  "extraKnownMarketplaces": {
    "vercel-vercel-plugin": {
      "source": {
        "source": "directory",
        "path": "__HOME__/.cache/plugins/github.com-vercel-vercel-plugin"
      }
    },
    "visual-explainer-marketplace": {
      "source": {
        "source": "github",
        "repo": "nicobailon/visual-explainer"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true
}
